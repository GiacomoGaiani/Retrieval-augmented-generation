cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*.so

# Virtual environment
venv/

# Local env / secrets
.env
*.env

# Chroma DB and embedding caches
chroma_db/
embeddings_cache/

# Models / large files
models/
*.bin
*.pt

# Personal documents (not for sharing)
docs/

# W&B local logs and artifacts
wandb/

# Benchmark result CSVs (personal runs)
*.csv

# VSCode / system files
.vscode/
.DS_Store
Thumbs.db
EOF