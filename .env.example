# ============================================================
# RAG Pipeline – environment configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored; .env.example is committed.
# ============================================================

# ── LLM ─────────────────────────────────────────────────────
# Ollama model to use (must be pulled first: `ollama pull mistral`)
LLM_MODEL=mistral

# When running inside Docker the app talks to the Ollama sidecar.
# When running locally, point to your local Ollama instance.
OLLAMA_HOST=http://localhost:11434

# Host port exposed by the Ollama container
OLLAMA_HOST_PORT=11434

# ── Embeddings ───────────────────────────────────────────────
# Embedder backend: "instructor" | "huggingface"
DEFAULT_EMBEDDER=instructor

# HuggingFace / InstructorEmbedding model name
DEFAULT_EMBED_MODEL=hkunlp/instructor-base

# ── ChromaDB ─────────────────────────────────────────────────
# Path inside the container (mapped to the chroma_data volume)
CHROMA_PERSIST_DIR=./chroma_db

# ── Chunking ─────────────────────────────────────────────────
CHUNK_SIZE=300
CHUNK_OVERLAP=50

# ── Retrieval ────────────────────────────────────────────────
# Number of chunks retrieved per query
RETRIEVAL_K=5

# Reciprocal Rank Fusion constant (v2 / v3 only)
RRF_K=60

# Maximum tokens passed to the LLM as context (v3 only)
TOKEN_BUDGET=3000

# ── Optional API keys ────────────────────────────────────────
# Only required if you switch from Ollama to OpenAI / Cohere backends
OPENAI_API_KEY=
COHERE_API_KEY=

# ── Weights & Biases ─────────────────────────────────────────
# Get your key at https://wandb.ai/authorize
WANDB_API_KEY=
# Project name shown in the W&B dashboard
WANDB_PROJECT=rag-benchmark
# Set to "disabled" to run benchmarks without W&B logging
WANDB_MODE=online

# ── Docs directory (docker-compose only) ─────────────────────
# Host path that will be mounted as /app/docs inside the container
DOCS_DIR=./docs
